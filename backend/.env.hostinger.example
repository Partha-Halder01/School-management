APP_NAME="Jamia Al Furqan"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.jamiafurqan.org

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stack
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=CHANGE_ME_DB_NAME
DB_USERNAME=CHANGE_ME_DB_USER
DB_PASSWORD=CHANGE_ME_DB_PASSWORD

CACHE_STORE=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync

FRONTEND_URL=https://jamiafurqan.org
FRONTEND_URL_WWW=https://www.jamiafurqan.org
SANCTUM_STATEFUL_DOMAINS=jamiafurqan.org,www.jamiafurqan.org

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@jamiafurqan.org"
MAIL_FROM_NAME="${APP_NAME}"
